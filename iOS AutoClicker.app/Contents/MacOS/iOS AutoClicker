#!/bin/bash
DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/../../.." >/dev/null 2>&1 && pwd )"
cd "$DIR"

export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

# Force ARM64 execution natively so Rosetta translation doesn't corrupt the PyQt6 library imports
arch -arm64 /bin/bash "./run.sh" > /tmp/ios_autoclicker_wrapper.log 2>&1
